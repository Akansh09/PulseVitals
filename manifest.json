{
    "name": "__MSG_extensionName__",
    "version": "2.1",
    "description": "__MSG_extensionDescription__",
    "default_locale": "en",
    "manifest_version": 3,
    "permissions": ["storage","activeTab","tabs"],
    "optional_permissions": ["notifications"],
    "icons": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "action": {
      "default_icon": {
        "16": "icons/16.png",
        "32": "icons/32.png",
        "48": "icons/48.png"
      },
      "default_title": "__MSG_extensionName__",
      "default_popup": "popup.html"
    },
    "options_ui": {
      "page": "options.html",
      "open_in_tab": true
    },
    "background": {
      "service_worker": "service-worker.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "run_at": "document_idle",
        "all_frames": false,
        "js": ["axe-lite.js", "background.js"]
      }
    ]
}
